# Provider selector — the ONLY switch. Options:
#   openai | anthropic | ollama | nvidia | nim
# Each provider below reads its own namespaced vars, so switching
# providers means changing this line alone; the others sit inert.
LLM_PROVIDER=nim

# --- openai -----------------------------------------------------------
# OPENAI_BASE_URL defaults to https://api.openai.com/v1
# OPENAI_MODEL    defaults to gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- anthropic --------------------------------------------------------
# ANTHROPIC_BASE_URL defaults to https://api.anthropic.com/v1
# ANTHROPIC_MODEL    defaults to claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1   
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- nvidia (hosted NIM via langchain_nvidia_ai_endpoints) ------------
# NVIDIA_BASE_URL defaults to https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL    defaults to moonshotai/kimi-k2.6
NVIDIA_API_KEY=your-nvidia-api-key-here
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=moonshotai/kimi-k2.6

# --- ollama (local daemon, no key) ------------------------------------
# OLLAMA_BASE_URL defaults to http://localhost:11434
# OLLAMA_MODEL    defaults to gemma4
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4

# --- nim (self-hosted container, no key) ------------------------------
# NIM_BASE_URL is REQUIRED for LLM_PROVIDER=nim (self-hosted NIMs have
# no canonical address). Must include the /v1 suffix. Also consumed by
# the `pytest -m live` NIM integration test.
# NIM_MODEL defaults to openai/gpt-oss-120b
NIM_BASE_URL=http://204.52.24.138:8000/v1
NIM_MODEL=meta/llama-3.3-70b-instruct
#NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Per-request chat_template_kwargs forwarded to vLLM. JSON object.
# Required for Nemotron-3 family NIMs to disable the default
# detailed-thinking chain-of-thought, which otherwise burns ~10x the
# output tokens on internal monologue the agent loop never reads.
# Safe to leave unset for non-Nemotron NIMs (vLLM ignores unknown keys).
# NIM_CHAT_TEMPLATE_KWARGS={"enable_thinking": false}

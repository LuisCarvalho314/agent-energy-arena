# Provider selector. Options: openai | anthropic | ollama | nvidia | nim
LLM_PROVIDER=anthropic

# Bearer / x-api-key for the chosen provider.
# Required for openai/anthropic/nvidia; ignored for ollama and nim (both
# target local, unauthenticated daemons).
# For nvidia, NVIDIA_API_KEY below is accepted as a fallback when this is unset.
LLM_API_KEY=your-llm-api-key-here

# Provider-specific model id. Defaults if unset:
#   openai     -> gpt-4o-mini
#   anthropic  -> claude-haiku-4-5-20251001
#   ollama     -> gemma4   (any tool-capable model: gemma/llama/qwen variants)
#   nvidia     -> moonshotai/kimi-k2.6
#   nim        -> openai/gpt-oss-120b
LLM_MODEL=claude-haiku-4-5-20251001

# Override the vendor's default base URL. Defaults if unset:
#   openai     -> https://api.openai.com/v1
#   anthropic  -> https://api.anthropic.com/v1
#   ollama     -> http://localhost:11434
#   nvidia     -> https://integrate.api.nvidia.com/v1
#   nim        -> (no default — set NIM_BASE_URL or LLM_BASE_URL)
#
# IMPORTANT: LLM_BASE_URL wins over NIM_BASE_URL when both are set.
# Leave this commented when LLM_PROVIDER=nim so the NIM_BASE_URL below
# is actually used. A stale Anthropic URL here is the most common
# footgun — the nim adapter will happily POST to api.anthropic.com
# and surface the 401 it gets back, which is bewildering to debug.
# LLM_BASE_URL=https://api.anthropic.com/v1

# Fallback API key consumed by the nvidia provider when LLM_API_KEY is unset.
NVIDIA_API_KEY=your-nvidia-api-key-here

# Self-hosted NIM container endpoint. Must include the /v1 suffix.
# Consumed by LLM_PROVIDER=nim when LLM_BASE_URL is unset, and by the
# `pytest -m live` NIM integration test.
NIM_BASE_URL=http://localhost:8000/v1

# Per-request chat_template_kwargs forwarded to vLLM. JSON object.
# Required for Nemotron-3 family NIMs to disable the default
# detailed-thinking chain-of-thought, which otherwise burns ~10x the
# output tokens on internal monologue the agent loop never reads.
# Safe to leave unset for non-Nemotron NIMs (vLLM ignores unknown keys).
NIM_CHAT_TEMPLATE_KWARGS={"enable_thinking": false}
